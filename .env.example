APP_ENV=local
DEV_AUTH_ENABLED=true
OIDC_ISSUER=
OIDC_AUDIENCE=
OIDC_JWKS_URL=
OIDC_JWKS_JSON=
OIDC_HS256_SECRET=
OIDC_ALLOWED_ALGORITHMS=["RS256","ES256","HS256"]
OIDC_EMAIL_CLAIMS=["email","preferred_username","upn"]
OIDC_GROUP_CLAIMS=["groups","roles"]
OIDC_GROUP_ROLE_MAP_JSON=
DATABASE_URL=postgresql+psycopg://control_plane:control_plane@postgres:5432/control_plane
REDIS_URL=redis://redis:6379/0
PROVIDER_MODE=mock
PROVIDER_LIVE_OPERATIONS_ENABLED=false
PROVIDER_WEBHOOK_SECRET=replace-me-for-non-local-use
LIFECYCLE_INLINE_EXECUTION=true
RATE_LIMIT_REQUESTS_PER_MINUTE=600
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_AUTH_MODE=development
NEXT_PUBLIC_OIDC_AUTHORIZATION_ENDPOINT=
NEXT_PUBLIC_OIDC_TOKEN_ENDPOINT=
NEXT_PUBLIC_OIDC_CLIENT_ID=
NEXT_PUBLIC_OIDC_REDIRECT_URI=http://localhost:3000
NEXT_PUBLIC_OIDC_SCOPE=openid profile email
API_PORT=8000
WEB_PORT=3000

# Live provider boundaries: store real secrets in a secret manager, not here.
AWS_REGION=us-east-1
AZURE_TENANT_ID=
GOOGLE_CLOUD_PROJECT=
GITHUB_ORG=
