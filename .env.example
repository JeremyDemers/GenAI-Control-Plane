REDIS_URL=redis://redis:6379/0
PROVIDER_MODE=mock
PROVIDER_WEBHOOK_SECRET=replace-me-for-non-local-use
NEXT_PUBLIC_API_URL=http://localhost:8000
API_PORT=8000
WEB_PORT=3000

# Live provider boundaries: store real secrets in a secret manager, not here.
AWS_REGION=us-east-1
AZURE_TENANT_ID=
GOOGLE_CLOUD_PROJECT=
GITHUB_ORG=
